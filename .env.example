# CareMate Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Anthropic API ─────────────────────────────────────────────
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database ──────────────────────────────────────────────────
# Get this from Railway after creating a PostgreSQL database
# It looks like: postgresql://postgres:password@host.railway.app:5432/railway
DATABASE_URL=postgresql://your-connection-string-here
